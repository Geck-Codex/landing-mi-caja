---
const links = [
  { label: 'Funciones', href: '#funciones' },
  { label: 'Precio',    href: '#precio' },
  { label: 'Soporte',   href: '#soporte' },
  { label: 'Contacto',  href: '#contacto' },
];
---

<footer style="border-top: 1px solid rgba(255,255,255,0.07)">
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">

    <!-- Logo -->
    <div class="flex flex-col items-center md:items-start gap-2">
      <a href="/" class="flex items-center gap-2.5">
        <img
          src="/logo/mi_caja.png"
          alt="MI CAJA"
          class="h-8 w-auto"
          onerror="this.style.display='none'"
        />
        <span class="font-display font-bold text-lg tracking-tight text-text">MI CAJA</span>
      </a>
      <p class="text-muted text-xs">Software de punto de venta · Chihuahua, México 🌵</p>
    </div>

    <!-- Links -->
    <nav class="flex gap-6 flex-wrap justify-center">
      {links.map((l) => (
        <a href={l.href} class="text-muted text-sm hover:text-text transition-colors duration-200">
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Copy + WA -->
    <div class="flex flex-col items-center md:items-end gap-2">
      <a
        href="https://wa.me/526141000000"
        target="_blank"
        rel="noopener noreferrer"
        class="text-verde text-sm font-semibold hover:underline"
      >
        +52 614 100 0000
      </a>
      <p class="text-muted/50 text-xs">© 2025 MI CAJA · Todos los derechos reservados</p>
    </div>

  </div>
</footer>
