---
const incluido = [
  'Licencia de software completa',
  '12 módulos incluidos desde el día 1',
  'Soporte por WhatsApp cuando lo necesites',
  'Actualizaciones de por vida',
  'Instalación y capacitación incluidas',
  'Sin mensualidades ni contratos',
];

const noIncluido = [
  'Mantenimiento de hardware (servicio aparte)',
  'Impresoras, lectores o cómputo (hardware)',
];

const comparativa = [
  {
    nombre: 'Microsip',
    precio: 'Licencia + anualidad',
    detalle: 'Soporte aparte, renovación cada año',
    destacado: false,
  },
  {
    nombre: 'Aspel POS',
    precio: 'Licencia + membresía anual',
    detalle: 'Requiere pago anual para actualizaciones',
    destacado: false,
  },
  {
    nombre: 'Software en la nube',
    precio: 'Mensualidad recurrente',
    detalle: 'Pagas mientras lo uses, sin internet no funciona',
    destacado: false,
  },
  {
    nombre: 'MI CAJA',
    precio: '$3,000 MXN',
    detalle: 'Pago único. Soporte incluido. Tuyo para siempre.',
    destacado: true,
  },
];
---

<section id="precio" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <p class="text-muted text-xs uppercase tracking-[0.2em] font-semibold mb-3">Precio</p>
      <h2 class="font-display font-bold text-4xl md:text-5xl tracking-tight">
        Precio único. <span class="text-gradient">Sin sorpresas.</span>
      </h2>
      <p class="text-muted mt-4 max-w-xl mx-auto">
        Un solo pago y el software es tuyo para siempre.
        Sin mensualidades, sin contratos, sin cobros ocultos.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

      <!-- Precio card principal -->
      <div
        class="reveal rounded-2xl p-8 relative overflow-hidden"
        style="background: rgba(26,225,122,0.04); border: 1px solid rgba(26,225,122,0.25)"
      >
        <div
          class="absolute -top-20 -right-20 w-56 h-56 rounded-full blur-[80px] pointer-events-none"
          style="background: rgba(26,225,122,0.1)"
        ></div>

        <div class="relative z-10">
          <div class="flex items-baseline gap-3 mb-2">
            <span class="font-display font-extrabold text-verde" style="font-size: 5rem; line-height: 1">$3,000</span>
            <div>
              <p class="text-text font-semibold">MXN</p>
              <p class="text-muted text-sm">Pago único</p>
            </div>
          </div>

          <p class="text-text font-semibold text-xl mb-8">
            Tuyo para siempre. Sin más pagos.
          </p>

          <div class="space-y-3 mb-6">
            <p class="text-xs uppercase tracking-widest text-muted font-semibold">Incluido</p>
            {incluido.map((item) => (
              <div class="flex items-center gap-3">
                <span class="w-5 h-5 rounded-full bg-verde/15 border border-verde/30 flex items-center justify-center flex-shrink-0 text-verde text-xs font-bold">✓</span>
                <span class="text-sm text-text">{item}</span>
              </div>
            ))}
          </div>

          <div class="space-y-3 mb-8 pt-4" style="border-top: 1px solid rgba(255,255,255,0.07)">
            <p class="text-xs uppercase tracking-widest text-muted font-semibold">No incluido</p>
            {noIncluido.map((item) => (
              <div class="flex items-center gap-3">
                <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 text-muted/50 text-xs" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08)">✗</span>
                <span class="text-sm text-muted">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="https://wa.me/526141000000?text=Hola%2C%20me%20interesa%20MI%20CAJA%20punto%20de%20venta.%0AMi%20negocio%20es%3A%20%5Btipo%5D%0AMi%20nombre%20es%3A%20%5Bnombre%5D"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-verde text-dark font-display font-bold text-base py-4 rounded-xl
                   hover:glow-verde hover:-translate-y-0.5 active:translate-y-0
                   transition-all duration-200"
          >
            Obtener MI CAJA por WhatsApp →
          </a>
        </div>
      </div>

      <!-- Comparativa local -->
      <div class="reveal flex flex-col gap-6">
        <div>
          <p class="text-muted text-xs uppercase tracking-widest font-semibold mb-4">
            ¿Por qué MI CAJA en lugar de las opciones de siempre?
          </p>
          <div class="space-y-3">
            {comparativa.map((c) => (
              <div
                class="flex items-start justify-between p-4 rounded-xl gap-4"
                style={c.destacado
                  ? 'background: rgba(26,225,122,0.06); border: 1px solid rgba(26,225,122,0.25)'
                  : 'background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07)'
                }
              >
                <div class="flex-1 min-w-0">
                  <p class={`font-display font-bold text-sm ${c.destacado ? 'text-verde' : 'text-text'}`}>
                    {c.nombre}
                  </p>
                  <p class="text-muted text-xs mt-0.5 leading-relaxed">{c.detalle}</p>
                </div>
                <div class="text-right flex-shrink-0">
                  <p class={`font-display font-bold ${c.destacado ? 'text-verde text-lg' : 'text-muted text-sm'}`}>
                    {c.precio}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Trust badges -->
        <div class="grid grid-cols-2 gap-3">
          {[
            { icon: '🇲🇽', text: 'Hecho en Chihuahua' },
            { icon: '💬', text: 'Soporte en español' },
            { icon: '🔒', text: 'Datos en tu equipo' },
            { icon: '⚡', text: 'Funciona sin internet' },
          ].map((b) => (
            <div
              class="flex items-center gap-3 p-3 rounded-xl"
              style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07)"
            >
              <span class="text-xl">{b.icon}</span>
              <span class="text-sm font-semibold text-text">{b.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
