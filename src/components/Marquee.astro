---
const items = [
  '✅ $3,500 pago único — nunca más',
  '⚡ Ventas rápidas',
  '🚫 Sin mensualidades',
  '📦 Control de inventario',
  '✅ Lo pagas una vez y ya quedó',
  '📊 Reportes en tiempo real',
  '🚫 Sin renovaciones anuales',
  '📒 Fiados y crédito',
  '✅ Actualizaciones de por vida',
  '👥 Múltiples cajeros',
  '🚫 Sin contratos',
  '🧾 Tickets térmicos',
];

const doubled = [...items, ...items];
---

<div
  class="relative overflow-hidden border-y py-4 marquee-fade"
  style="border-color: rgba(255,255,255,0.07)"
>
  <div
    class="flex whitespace-nowrap animate-marquee hover:[animation-play-state:paused]"
  >
    {doubled.map((item) => (
      <span class="inline-flex items-center gap-2 px-8 text-muted text-sm font-semibold tracking-wide flex-shrink-0">
        {item}
        <span class="w-1.5 h-1.5 rounded-full bg-verde/40 ml-2" aria-hidden="true"></span>
      </span>
    ))}
  </div>
</div>
